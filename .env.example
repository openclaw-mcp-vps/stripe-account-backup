NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Required for server-side Stripe API calls (OAuth + webhook event enrichment)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxxxxxx

# Cookie/session signing secret
APP_AUTH_SECRET=replace-with-a-long-random-string

# Optional deployment URL override (used for Stripe OAuth redirect_uri)
APP_BASE_URL=http://localhost:3000

# Optional internal scheduler controls
ENABLE_INTERNAL_CRON=false
BACKUP_CRON_SCHEDULE=0 3 * * *
CRON_SECRET=replace-with-cron-secret

# Optional S3 storage configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=
AWS_S3_BUCKET=
